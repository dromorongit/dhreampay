# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-32-character-random-secret-string-here-replace-in-production

# Backend API URL
NEXT_PUBLIC_API_URL=https://dhreampay-production.up.railway.app

# Note for Railway production deployment:
# - Set NEXTAUTH_URL to your frontend Railway URL (e.g., https://dhreampay-frontend.up.railway.app)
# - Generate a strong random string for NEXTAUTH_SECRET (32+ characters)